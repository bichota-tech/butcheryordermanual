{
  "name": "vue-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@tailwindcss/vite": "^4.1.14",
    "better-sqlite3": "^12.4.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-vue-next": "^0.577.0",
    "motion": "^12.23.24",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.21",
    "prisma": "6.19.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vue-tsc": "^3.2.5"
  }
